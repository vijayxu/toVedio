# 密钥与本地配置（勿提交）
.env
.env.local
*.local.env

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# 过程产物（默认仓库 artifacts/；可用 TOVEDIO_ARTIFACT_DIR 改到别处）
